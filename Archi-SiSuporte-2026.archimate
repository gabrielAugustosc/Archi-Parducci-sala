  <folder name="Strategy" id="id-9b34bf6552fd4b66a769b9217cf63dae" type="strategy"/>
  <folder name="Business" id="id-847f4a5857d844458f04cb66222ba3a5" type="business"/>
  <folder name="Application" id="id-ffb626ae011e4d1d81f7b63005ac509c" type="application"/>
  <folder name="Technology &amp; Physical" id="id-538be68e595741c5b034fc1dd1adb0e6" type="technology"/>
  <folder name="Motivation" id="id-6689f970f5104e5ea15128ecadd10478" type="motivation">
    <element xsi:type="archimate:Value" name="Value" id="id-edbb1647b9b84d15b6aa974499cbc336"/>
    <element xsi:type="archimate:Stakeholder" name="Presidente Software House Super Solucoes" id="id-d65830e8e3b24338aecb4339805d2e3f"/>
    <element xsi:type="archimate:Driver" name="Formalizar todo atendimento de suporte" id="id-792a1d5fdddb47a38c64c0c693d85e56"/>
    <element xsi:type="archimate:Driver" name="Conhecer o desempenho da equipe de suporte" id="id-ff0e72ba532341aba153443efc4ef914"/>
    <element xsi:type="archimate:Driver" name="Conhecer o nível de satisfação dos clientes" id="id-44a7cc981a2f465a8f6557e6c54fce78"/>
    <element xsi:type="archimate:Principle" name="Entre os indicadores de desempenho é obrigatória a medição de tempo de ciclo de atendimento do registro à solução do chamado" id="id-7515f4bd002c43418c58d7245f4088d6"/>
    <element xsi:type="archimate:Principle" name="Coletar feedback de todos os clientes que abriram chamados técnicos" id="id-a3624577932e4ed3afaabf0ca14bd82f"/>
    <element xsi:type="archimate:Principle" name="Registrar dados sobre cada demanda feita no suporte, permitindo a recuperação da  informação e acompanhamento do atendimento" id="id-3fe28ad936a8453ba291d66c66bf195a"/>
    <element xsi:type="archimate:Goal" name="Realizar pesquisa de stisfação com o cliente atendido" id="id-348565dcf67243b8b71020b51d396dbf"/>
    <element xsi:type="archimate:Goal" name="Gerar métricas  que apontem a performace dos atendentes de suporte" id="id-81a16ff9c43a4a59ade97f94c08ba235"/>
    <element xsi:type="archimate:Goal" name="Workflow para registrar, movimentar e solucinar chamados técnicos " id="id-9f9bc0b0c58745fdb79c17f262263fbd"/>
    <element xsi:type="archimate:Goal" name="Garantir que 100% dos chamados com atendimento finalizado tenham disparo de pesquisa de satisfação com o cliente atendido" id="id-6a4482866c9b4b83960667fea7b3a25d"/>
    <element xsi:type="archimate:Goal" name="Os indicadores de desempenho serão mapeados contra o SLA (Acordo de nível de serviço/meta)" id="id-e3a9ec9ef8b64f158ee6875b282fbccb"/>
    <element xsi:type="archimate:Goal" name="Alta disponibilidade e acessibilidade do sistema de registro e acompanhamento de chamados" id="id-b51ea7d116f4464eafdd176192ab737d"/>
    <element xsi:type="archimate:Outcome" name="Alta disponibilidade e acessibilidade do sistema de registro e acompanhamento de chamados" id="id-f08e7f1036d349d9bf98ff2e2681d3ea"/>
    <element xsi:type="archimate:Outcome" name="Os indicadores de desempenho serão mapeados contra o SLA (Acordo de nível de serviço/meta)" id="id-609593d8debd44068c86b825f93fcf70"/>
    <element xsi:type="archimate:Assessment" name="Usar um meio de comunicação digital usal dos clientes" id="id-ed8f9e0c1f694e6d8a5b7c4b12c70dcf"/>
    <element xsi:type="archimate:Outcome" name="Garantir que 100% dos chamados com atendimento finalizado tenham disparo de pesquisa de satisfação com o cliente atendido" id="id-c465e981fcb64ed48c11302806652882"/>
    <element xsi:type="archimate:Assessment" name="Disponibilizar os dados do sistema transacionalde help desk para serem consultados na solução que já existe na empresa" id="id-d063691617e745e2927128fcf9839b05"/>
    <element xsi:type="archimate:Assessment" name="Desenvolver a aplicação do zero com a tecnologia permita mobilidade" id="id-89ca732fa9004f0d9bd89d4aa54d0fb2"/>
    <element xsi:type="archimate:Outcome" name="Disparar pesquisa de satisfação" id="id-2e910d42ee1e40a39bcbc93da4cbbcaf"/>
    <element xsi:type="archimate:Requirement" name="Coletar feedback do cliente" id="id-a57fcb282f024c3ab6fea841b6fe6383"/>
    <element xsi:type="archimate:Constraint" name="A cada chamado com atendimento conluído (solucionado), uma mensagem será enviada por e-mail, sendo que essa mensagem contém: texto padrão de apresentação da pesquisa, a identificação dp problema original, descrição da solução, data e hora de fechamento do e lista de itens de avaliação com opções fixas de resposta (listas de seleção)" id="id-4cdecfb312654b5f8314050df27c5974"/>
    <element xsi:type="archimate:Constraint" name="Uma aplicação de software vai ler as mensagens de resposta com os formulários de pesquisa preenchidos e guardar as opções de cada resposta dada em uma base de dados de resultados de pesquisa por chamado" id="id-7a1dbe2565994b9e8b72bec1e61e4b18"/>
  </folder>
